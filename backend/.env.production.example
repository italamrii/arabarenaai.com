# Backend — production template (set in Render Dashboard → Environment)
# Never commit real values. Copy keys only.

# --- Required ---

# Supabase: use Session pooler (port 5432) or Direct connection for Render web service.
# Append ?sslmode=require if not included by Supabase.
# Example (Session pooler):
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=

# Generate: openssl rand -hex 32
SESSION_SECRET=

# Production environment flag (disables /docs and debug routes)
APP_ENV=production

# Admin secret for operational endpoints — set same value as Vercel ADMIN_API_SECRET
# Generate: openssl rand -hex 32
ADMIN_API_SECRET=

# Comma-separated extra origins (no trailing slash).
# https://arabarenaai.com and https://www.arabarenaai.com are always allowed by default.
# Add Vercel preview/production URLs here, e.g.:
# CORS_ORIGINS=https://arabarenaai.vercel.app,https://arab-benchmark-ai.vercel.app
CORS_ORIGINS=https://arabarenaai.com,https://www.arabarenaai.com

# --- Recommended ---

APP_VERSION=1.0.0
LOG_LEVEL=INFO
LOG_FORMAT=json
CATEGORY_CLASSIFIER_MODEL=gpt-4o-mini
CATEGORY_CONFIDENCE_THRESHOLD=0.6

# --- Provider API keys (at least one required for live comparisons) ---

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
XAI_API_KEY=
ALLAM_API_KEY=

# --- Optional overrides ---

DEEPSEEK_BASE_URL=https://api.deepseek.com
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
XAI_BASE_URL=https://api.x.ai/v1
