# Backend
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/arab_benchmark
SESSION_SECRET=change-me-in-production
APP_VERSION=1.0.0
# Comma-separated extra origins (Vercel preview/production URLs, etc.).
# https://arabarenaai.com and https://www.arabarenaai.com are always allowed by default.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Observability (production: LOG_FORMAT=json)
LOG_LEVEL=INFO
LOG_FORMAT=text

# Category auto-detect (uses OpenAI-compatible API)
CATEGORY_CLASSIFIER_MODEL=gpt-4o-mini
CATEGORY_CONFIDENCE_THRESHOLD=0.6

# Provider API keys (never commit real values)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
XAI_API_KEY=
ALLAM_API_KEY=

# Spending protection
MAX_MODELS_PER_COMPARISON=4
MIN_MODELS_PER_COMPARISON=2
MAX_PROMPT_CHARS=1000
PROVIDER_MAX_TOKENS=1600

# Optional provider base URL overrides
DEEPSEEK_BASE_URL=https://api.deepseek.com
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
XAI_BASE_URL=https://api.x.ai/v1
