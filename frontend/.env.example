# Public API base URL (must include /v1 suffix)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/v1

# Public site URL for SEO canonical/sitemap (production: https://arabarenaai.com)
NEXT_PUBLIC_SITE_URL=https://arabarenaai.com

# Analytics (optional — scripts load only when set)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Server-only admin credentials (never use NEXT_PUBLIC_ prefix)
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Optional server-only metadata for admin system overview (never use NEXT_PUBLIC_ prefix)
# BUILD_TIMESTAMP=2026-06-07T12:00:00Z
